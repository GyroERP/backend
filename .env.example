# =============================================================================
# GyroERP Backend — Environment variables (example)
# =============================================================================
# Copy this file to `.env` and fill in values for local development.
# Never commit `.env` — it is listed in `.gitignore`.
# =============================================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=gyroerp.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database ---
# SQLite is used when DATABASE_URL is unset (local dev without Docker)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (Docker Compose sets this automatically for the web service):
# DATABASE_URL=postgres://gyroerp:gyroerp@localhost:5432/gyroerp

# --- Security (production) ---
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.gyroerp.com
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True

# --- Static & media ---
# DJANGO_STATIC_ROOT=staticfiles
# DJANGO_MEDIA_ROOT=media

# --- Email (optional) ---
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@gyroerp.com

# --- Redis / Celery (optional, for async ERP tasks) ---
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS (when frontend runs on a separate origin) ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Logging ---
# DJANGO_LOG_LEVEL=INFO
